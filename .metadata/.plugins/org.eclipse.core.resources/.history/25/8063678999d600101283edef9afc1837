package TP5;

class ComparaisonListe {
    public static long mesurerTempsInsertion(List<Integer> liste, int nombreElements) {
        long debut = System.currentTimeMillis();
        
        for (int i = 0; i < nombreElements; i++) {
            liste.add(liste.size() / 2, i);
        }
        
        long fin = System.currentTimeMillis();
        return fin - debut;
    }
}
